        for(int i = 0; i < s1.length(); i++)
        {
            freq[s1.charAt(i) - 'a']++;
            freq[s2.charAt(i) - 'a']--;
        }


        boolean flag = true;


        for(int i = 0; i < 26; i++)
        {
            if(freq[i] != 0)
            {
                flag = false;
                break;
            }
        }


        if(flag)
        {
            System.out.println("Anagram");
        }
        else
        {
            System.out.println("Not Anagram");
        }


