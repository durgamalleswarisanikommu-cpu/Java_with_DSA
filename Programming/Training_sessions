        int temp = n;
        int binary = 0;
        int place = 1;


        // Convert decimal to binary number
        while(temp > 0)
        {
            int digit = temp % 2;

            binary = binary + digit * place;

            place = place * 10;

            temp = temp / 2;
        }


        int original = binary;
        int reverse = 0;


        // Reverse binary number
        while(binary > 0)
        {
            int digit = binary % 10;

            reverse = reverse * 10 + digit;

            binary = binary / 10;
        }


        if(original == reverse)
        {
            System.out.println("Binary Palindrome");
        }
        else
        {
            System.out.println("Not Binary Palindrome");
        }


        sc.close();
    }
}

