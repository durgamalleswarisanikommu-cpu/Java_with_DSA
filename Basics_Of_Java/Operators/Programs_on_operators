import java.util.*;

class TernaryOperator
{
    public static void main(String args[])
    {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        String result = (n % 2 == 0) ? "Even" : "Odd";

        System.out.println(result);
    }
}
8. Find Largest Using Ternary Operator

LargestUsingTernary.java

import java.util.*;

class LargestUsingTernary
{
    public static void main(String args[])
    {
        Scanner sc = new Scanner(System.in);

        int a = sc.nextInt();
        int b = sc.nextInt();

        int largest = (a > b) ? a : b;

        System.out.println("Largest = " + largest);
    }
}
9. Swap Two Numbers Using Operators

SwapUsingOperators.java

import java.util.*;

class SwapUsingOperators
{
    public static void main(String args[])
    {
        Scanner sc = new Scanner(System.in);

        int a = sc.nextInt();
        int b = sc.nextInt();

        a = a + b;
        b = a - b;
        a = a - b;

        System.out.println("a = " + a);
        System.out.println("b = " + b);
    }
}
10. Check Even Odd Using Bitwise Operator

EvenOddUsingBitwise.java

import java.util.*;

class EvenOddUsingBitwise
{
    public static void main(String args[])
    {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        if((n & 1) == 0)
        {
            System.out.println("Even");
        }
        else
        {
            System.out.println("Odd");
        }
    }
}
